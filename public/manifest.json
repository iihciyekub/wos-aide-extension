{
  "manifest_version": 3,
  "name": "WOS Aide",
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "version": "0.1.3",
  "description": "WOS Aide Chrome Extension",
  "icons": {
    "16": "icons/icon_16.png",
    "32": "icons/icon_32.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "WOS Aide",
    "default_popup": "popup.html"
  },
  "permissions": [
    "storage",
    "clipboardWrite",
    "activeTab",
    "scripting"
  ],
  "optional_host_permissions": [
    "https://api.openai.com/*",
    "https://www.easyscholar.cc/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.webofscience.com/*",
        "https://*.webofscience.com/*",
        "*://*.webofknowledge.com/*",
        "*://*.isiknowledge.com/*"
      ],
      "run_at": "document_idle",
      "js": [
        "contentScript.js"
      ]
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*"
      ],
      "run_at": "document_idle",
      "js": [
        "contentScript.js"
      ]
    },
    {
      "matches": [
        "https://www.webofscience.com/*",
        "https://*.webofscience.com/*",
        "*://*.webofknowledge.com/*",
        "*://*.isiknowledge.com/*"
      ],
      "run_at": "document_start",
      "js": [
        "z-Wos-loader.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "z-Wos.js",
        "jquery-3.7.0.js",
        "all.min.css",
        "all.min.js",
        "pub-fun.js",
        "z-easyscholar.js",
        "z-wos-doi-query.js",
        "z-chat.js",
        "prompts/wos-query.md",
        "injected.js",
        "module-bridge.js",
        "webfonts/*.woff2",
        "webfonts/*.ttf"
      ],
      "matches": [
        "https://www.webofscience.com/*",
        "https://*.webofscience.com/*",
        "*://*.webofknowledge.com/*",
        "*://*.isiknowledge.com/*"
      ]
    },
    {
      "resources": [
        "chatgpt-prompts-quickload.js"
      ],
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*"
      ]
    },
    {
      "resources": [
        "pub-fun.js",
        "z-doi-pdf-download.js",
        "all.min.css",
        "all.min.js",
        "webfonts/*.woff2",
        "webfonts/*.ttf"
      ],
      "matches": [
        "https://*/*"
      ]
    }
  ]
}
